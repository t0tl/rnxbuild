{
  "name": "ExpoModulesJSI",
  "version": "56.0.10",
  "summary": "The JavaScript Interface for Expo Modules",
  "description": "The JavaScript Interface for Expo Modules",
  "license": "MIT",
  "authors": "650 Industries, Inc.",
  "homepage": "https://github.com/expo/expo/tree/main/packages/expo-modules-jsi",
  "platforms": {
    "ios": "16.4",
    "osx": "13.4",
    "tvos": "16.4"
  },
  "swift_versions": "6.0",
  "source": {
    "git": "https://github.com/expo/expo.git"
  },
  "static_framework": true,
  "header_dir": "ExpoModulesJSI",
  "pod_target_xcconfig": {
    "USE_HEADERMAP": "YES",
    "DEFINES_MODULE": "YES",
    "HEADER_SEARCH_PATHS": "",
    "CLANG_CXX_LANGUAGE_STANDARD": "c++20",
    "FRAMEWORK_SEARCH_PATHS": "\"${PODS_CONFIGURATION_BUILD_DIR}/XCFrameworkIntermediates/ExpoModulesJSI\""
  },
  "dependencies": {
    "React-Core": [

    ],
    "ReactCommon": [

    ]
  },
  "prepare_command": "./scripts/create-stub-xcframework.sh",
  "vendored_frameworks": [
    "Products/ExpoModulesJSI.xcframework"
  ],
  "script_phases": {
    "name": "Build ExpoModulesJSI xcframework",
    "script": "\"${PODS_TARGET_SRCROOT}/scripts/build-xcframework.sh\"",
    "execution_position": "before_headers",
    "always_out_of_date": "1"
  },
  "testspecs": [
    {
      "name": "Tests",
      "test_type": "unit",
      "source_files": "Tests/**/*.swift",
      "pod_target_xcconfig": {
        "FRAMEWORK_SEARCH_PATHS": "$(inherited) \"$(SDKROOT)/System/Library/SubFrameworks\"",
        "OTHER_LDFLAGS": "$(inherited) -lc++"
      }
    }
  ],
  "swift_version": "6.0"
}
