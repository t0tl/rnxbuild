{
  "name": "React-domnativemodule",
  "version": "0.85.3",
  "summary": "React Native DOM native module",
  "homepage": "https://reactnative.dev/",
  "license": "MIT",
  "authors": "Meta Platforms, Inc. and its affiliates",
  "platforms": {
    "ios": "15.1"
  },
  "source": {
    "git": "https://github.com/facebook/react-native.git",
    "tag": "v0.85.3"
  },
  "source_files": "*.h",
  "header_dir": "react/nativemodule/dom",
  "pod_target_xcconfig": {
    "CLANG_CXX_LANGUAGE_STANDARD": "c++20",
    "HEADER_SEARCH_PATHS": "\"$(PODS_ROOT)/Headers/Private/Yoga\" \"${PODS_ROOT}/React-runtimeexecutor\" \"${PODS_ROOT}/React-runtimeexecutor/platform/ios\" \"${PODS_ROOT}/React-graphics\" \"${PODS_ROOT}/React-graphics/react/renderer/graphics/platform/ios\" \"${PODS_ROOT}/React-RCTFBReactNativeSpec\"",
    "OTHER_CFLAGS": "$(inherited) -ivfsoverlay $(PODS_ROOT)/React-Core-prebuilt/React-VFS.yaml",
    "DEFINES_MODULE": "YES",
    "OTHER_CPLUSPLUSFLAGS": "$(inherited) -ivfsoverlay $(PODS_ROOT)/React-Core-prebuilt/React-VFS.yaml",
    "OTHER_SWIFT_FLAGS": "$(inherited) -Xcc -ivfsoverlay -Xcc $(PODS_ROOT)/React-Core-prebuilt/React-VFS.yaml"
  },
  "dependencies": {
    "React-jsi": [

    ],
    "React-jsiexecutor": [

    ],
    "hermes-engine": [

    ],
    "ReactNativeDependencies": [

    ],
    "React-Core-prebuilt": [

    ],
    "Yoga": [

    ],
    "ReactCommon/turbomodule/core": [

    ],
    "React-Fabric": [

    ],
    "React-Fabric/bridging": [

    ],
    "React-FabricComponents": [

    ],
    "React-runtimeexecutor": [

    ],
    "React-graphics": [

    ],
    "React-RCTFBReactNativeSpec": [

    ]
  }
}
