{
  "name": "React-RCTRuntime",
  "version": "0.85.3",
  "summary": "RCTRuntime for React Native.",
  "homepage": "https://reactnative.dev/",
  "license": "MIT",
  "authors": "Meta Platforms, Inc. and its affiliates",
  "platforms": {
    "ios": "15.1"
  },
  "source": {
    "git": "https://github.com/facebook/react-native.git",
    "tag": "v0.85.3"
  },
  "source_files": "*.h",
  "compiler_flags": "-DRCT_NEW_ARCH_ENABLED=1",
  "header_dir": "React",
  "module_name": "RCTRuntime",
  "pod_target_xcconfig": {
    "OTHER_CFLAGS": "$(inherited)  -DRCT_NEW_ARCH_ENABLED=1 -ivfsoverlay $(PODS_ROOT)/React-Core-prebuilt/React-VFS.yaml",
    "DEFINES_MODULE": "YES",
    "CLANG_CXX_LANGUAGE_STANDARD": "c++20",
    "HEADER_SEARCH_PATHS": "\"${PODS_ROOT}/React-debug\" \"${PODS_ROOT}/React-runtimeexecutor\" \"${PODS_ROOT}/React-runtimeexecutor/platform/ios\" \"${PODS_ROOT}/React-jsitooling\" \"${PODS_ROOT}/React-jsinspector\" \"${PODS_ROOT}/React-jsinspectorcdp\" \"${PODS_ROOT}/React-jsinspectortracing\" \"${PODS_ROOT}/React-RuntimeCore\" \"${PODS_ROOT}/React-RuntimeApple\" \"${PODS_ROOT}/React-utils\" \"${PODS_ROOT}/React-utils/react/utils/platform/ios\" \"${PODS_ROOT}/React-RuntimeHermes\"",
    "OTHER_CPLUSPLUSFLAGS": "$(inherited) -ivfsoverlay $(PODS_ROOT)/React-Core-prebuilt/React-VFS.yaml",
    "OTHER_SWIFT_FLAGS": "$(inherited) -Xcc -ivfsoverlay -Xcc $(PODS_ROOT)/React-Core-prebuilt/React-VFS.yaml"
  },
  "dependencies": {
    "React-Core": [

    ],
    "React-jsi": [

    ],
    "React-debug": [

    ],
    "React-runtimeexecutor": [

    ],
    "React-jsitooling": [

    ],
    "React-jsinspector": [

    ],
    "React-jsinspectorcdp": [

    ],
    "React-jsinspectortracing": [

    ],
    "React-RuntimeCore": [

    ],
    "React-RuntimeApple": [

    ],
    "React-utils": [

    ],
    "hermes-engine": [

    ],
    "React-RuntimeHermes": [

    ],
    "ReactNativeDependencies": [

    ],
    "React-Core-prebuilt": [

    ]
  },
  "exclude_files": "RCTJscInstanceFactory.{h,mm}"
}
