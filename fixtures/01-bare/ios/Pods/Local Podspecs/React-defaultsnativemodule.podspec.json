{
  "name": "React-defaultsnativemodule",
  "version": "0.85.3",
  "summary": "React Native Default native modules",
  "homepage": "https://reactnative.dev/",
  "license": "MIT",
  "authors": "Meta Platforms, Inc. and its affiliates",
  "platforms": {
    "ios": "15.1"
  },
  "source": {
    "git": "https://github.com/facebook/react-native.git",
    "tag": "v0.85.3"
  },
  "source_files": "*.h",
  "header_dir": "react/nativemodule/defaults",
  "pod_target_xcconfig": {
    "CLANG_CXX_LANGUAGE_STANDARD": "c++20",
    "HEADER_SEARCH_PATHS": "\"$(PODS_ROOT)/Headers/Private/Yoga\" \"${PODS_ROOT}/React-RCTFBReactNativeSpec\" \"${PODS_ROOT}/React-featureflags\" \"${PODS_ROOT}/React-featureflagsnativemodule\"",
    "OTHER_CFLAGS": "$(inherited) -ivfsoverlay $(PODS_ROOT)/React-Core-prebuilt/React-VFS.yaml",
    "DEFINES_MODULE": "YES",
    "OTHER_CPLUSPLUSFLAGS": "$(inherited) -ivfsoverlay $(PODS_ROOT)/React-Core-prebuilt/React-VFS.yaml",
    "OTHER_SWIFT_FLAGS": "$(inherited) -Xcc -ivfsoverlay -Xcc $(PODS_ROOT)/React-Core-prebuilt/React-VFS.yaml"
  },
  "dependencies": {
    "Yoga": [

    ],
    "React-jsi": [

    ],
    "React-jsiexecutor": [

    ],
    "hermes-engine": [

    ],
    "ReactNativeDependencies": [

    ],
    "React-Core-prebuilt": [

    ],
    "React-domnativemodule": [

    ],
    "React-microtasksnativemodule": [

    ],
    "React-idlecallbacksnativemodule": [

    ],
    "React-intersectionobservernativemodule": [

    ],
    "React-mutationobservernativemodule": [

    ],
    "React-webperformancenativemodule": [

    ],
    "React-Fabric/animated": [

    ],
    "React-RCTFBReactNativeSpec": [

    ],
    "React-featureflags": [

    ],
    "React-featureflagsnativemodule": [

    ]
  }
}
