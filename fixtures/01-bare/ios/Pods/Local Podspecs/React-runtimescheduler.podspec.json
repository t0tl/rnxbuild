{
  "name": "React-runtimescheduler",
  "version": "0.85.3",
  "summary": "-",
  "homepage": "https://reactnative.dev/",
  "license": "MIT",
  "authors": "Meta Platforms, Inc. and its affiliates",
  "platforms": {
    "ios": "15.1"
  },
  "source": {
    "git": "https://github.com/facebook/react-native.git",
    "tag": "v0.85.3"
  },
  "source_files": "**/*.h",
  "header_dir": "react/renderer/runtimescheduler",
  "exclude_files": "tests",
  "pod_target_xcconfig": {
    "CLANG_CXX_LANGUAGE_STANDARD": "c++20",
    "HEADER_SEARCH_PATHS": "\"${PODS_ROOT}/React-runtimeexecutor\" \"${PODS_ROOT}/React-runtimeexecutor/platform/ios\" \"${PODS_ROOT}/React-debug\" \"${PODS_ROOT}/React-jsinspectortracing\"",
    "OTHER_CFLAGS": "$(inherited) -ivfsoverlay $(PODS_ROOT)/React-Core-prebuilt/React-VFS.yaml",
    "OTHER_CPLUSPLUSFLAGS": "$(inherited) -ivfsoverlay $(PODS_ROOT)/React-Core-prebuilt/React-VFS.yaml",
    "OTHER_SWIFT_FLAGS": "$(inherited) -Xcc -ivfsoverlay -Xcc $(PODS_ROOT)/React-Core-prebuilt/React-VFS.yaml"
  },
  "dependencies": {
    "React-runtimeexecutor": [

    ],
    "React-callinvoker": [

    ],
    "React-cxxreact": [

    ],
    "React-rendererdebug": [

    ],
    "React-utils": [

    ],
    "React-featureflags": [

    ],
    "React-timing": [

    ],
    "React-jsi": [

    ],
    "React-performancetimeline": [

    ],
    "React-rendererconsistency": [

    ],
    "React-debug": [

    ],
    "React-jsinspectortracing": [

    ],
    "hermes-engine": [

    ],
    "ReactNativeDependencies": [

    ],
    "React-Core-prebuilt": [

    ]
  }
}
