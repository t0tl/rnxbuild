# Bundle artifacts
*.jsbundle

# CocoaPods — binary artifact directories are too large to commit (>1 GB of
# prebuilt XCFrameworks and tarballs in RN 0.85+). Commit Pods.xcodeproj,
# Manifest.lock, Target Support Files, and Local Podspecs (all text, <5 MB)
# but skip the binary-heavy subdirectories.
/Pods/React-Core-prebuilt/
/Pods/ReactNativeCore-artifacts/
/Pods/ReactNativeDependencies/
/Pods/ReactNativeDependencies-artifacts/
/Pods/hermes-engine/
/Pods/hermes-engine-artifacts/
/Pods/Headers/
